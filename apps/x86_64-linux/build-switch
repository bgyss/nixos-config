#!/bin/sh -e

VERSION=1.0

GREEN='\033[1;32m'
RED='\033[1;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# nixosConfigurations are keyed by hostname (F5), matching the idiomatic
# `nixos-rebuild --flake .#<hostname>` selection. Add an entry for this host to
# `nixosHosts` in flake.nix if one does not exist yet.
FLAKE_TARGET="$(hostname -s 2>/dev/null || hostname)"

echo -e "${YELLOW}Starting (target: .#${FLAKE_TARGET})...${NC}"

# We pass SSH from user to root so root can download secrets from our private Github
sudo SSH_AUTH_SOCK=$SSH_AUTH_SOCK /run/current-system/sw/bin/nixos-rebuild switch --flake .#$FLAKE_TARGET $@

echo -e "${GREEN}Switch to new generation complete!${NC}"
