#!/usr/bin/env bash
# Read-only preview (§5.3): build the darwin system this flake WOULD produce
# and print the store closure delta vs the running system. Activates nothing.
# Agents should be able to propose-and-preview before they switch.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/_common.sh"

FLAKE_DIR="$(locate_flake)" || exit 1

out_link="$(mktemp -d)/result"
trap 'rm -rf "$(dirname "$out_link")"' EXIT

warn "==> building ${FLAKE_SYSTEM_ATTR} (no activation)"
nix build "${FLAKE_DIR}#${FLAKE_SYSTEM_ATTR}" --out-link "$out_link" "$@"

warn "==> store closure diff (running system -> proposed)"
nix store diff-closures /run/current-system "$out_link"

msg "Preview complete. Nothing was activated."
