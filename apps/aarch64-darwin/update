#!/usr/bin/env bash
# Convenience wrapper: the full update in one shot = prepare (propose) then
# activate (switch). For agentic / unattended use prefer running the two halves
# separately so the privileged switch consumes a reviewed, committed revision
# (see apps/aarch64-darwin/{prepare,activate} and §5.4 of the config survey).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

"$SCRIPT_DIR/prepare"
exec "$SCRIPT_DIR/activate" HEAD
