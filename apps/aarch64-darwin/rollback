#!/usr/bin/env bash
# The agent's undo button (§5.5): roll the darwin system back to a previous
# generation. Machine-invocable and idempotent.
#
# Usage:
#   rollback                 roll back to the immediately-previous generation
#   rollback <generation>    roll back to a specific generation number
#   rollback --list          list generations and exit
#
# Idempotent: activating a generation that is already current is a no-op switch.
# (Note: --switch-generation does not take --flake; it activates an existing
# generation's store path directly.)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/_common.sh"

darwin_rebuild=/run/current-system/sw/bin/darwin-rebuild

if [[ "${1:-}" == "--list" ]]; then
  "$darwin_rebuild" --list-generations
  exit 0
fi

if [[ -n "${1:-}" ]]; then
  gen="$1"
  [[ "$gen" =~ ^[0-9]+$ ]] || { err "generation must be a number (or --list); got: $gen"; exit 1; }
  warn "==> rolling back to generation $gen"
  exec sudo -H -- "$darwin_rebuild" switch --switch-generation "$gen"
fi

# No argument: the immediately-previous generation (second-newest in the list).
prev=$("$darwin_rebuild" --list-generations \
  | awk '{print $1}' | grep -E '^[0-9]+$' | sort -n | tail -2 | head -1)
if [[ -z "$prev" ]]; then
  err "no previous generation to roll back to"
  exit 1
fi
warn "==> rolling back to previous generation $prev"
exec sudo -H -- "$darwin_rebuild" switch --switch-generation "$prev"
