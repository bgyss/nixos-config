#!/usr/bin/env bash
# Verify and fix stale sha256 hashes in prebuilt-binary overlays.
# Run after `nix flake update` and before `build-switch`.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/_common.sh"

# Back-compat color names used below.
GREEN="$C_GREEN"; YELLOW="$C_YELLOW"; RED="$C_RED"; NC="$C_NC"

# The script runs from a read-only Nix store path, so locate the mutable repo.
FLAKE_DIR="$(locate_flake)" || exit 1
OVERLAYS_DIR="$FLAKE_DIR/overlays"

# Parse --only argument to filter to specific overlay names
ONLY=""
if [[ "${1:-}" == "--only" ]]; then ONLY="${2:-}"; shift 2 || true; fi

total=0
fixed=0
errors=0

# Extract (url, hash) pairs from a nix overlay file.
# Handles both `hash = "sha256-..."` and `sha256 = "sha256-..."` attribute names.
# Substitutes the `version` and `base` Nix variables into URLs (e.g. ${version} -> "1.2.3").
extract_pairs() {
  python3 - "$1" <<'PYEOF'
import re, sys
text = open(sys.argv[1]).read()

# Resolve the `version` variable so URLs like ${version} become concrete.
version_match = re.search(r'\bversion\s*=\s*"([^"]+)"', text)
version = version_match.group(1) if version_match else ""

# Resolve the `base` variable so URLs like ${base}/... become concrete.
base_match = re.search(r'\bbase\s*=\s*"([^"]+)"', text)
base = base_match.group(1) if base_match else ""
# Substitute version in base (e.g. base might contain ${version})
base = base.replace("${version}", version)

urls   = re.findall(r'url\s*=\s*"([^"]+)"', text)
hashes = re.findall(r'(?:hash|sha256)\s*=\s*"(sha256-[^\s"]+)"', text)
for u, h in zip(urls, hashes):
    u = u.replace("${version}", version)
    u = u.replace("${base}", base)
    print(u + "\t" + h)
PYEOF
}

# Compute SRI sha256 for a URL using plain fetchurl semantics (hash of the file, not unpacked).
sri_for_url() {
  local url="$1"
  local raw
  raw=$(nix-prefetch-url "$url" 2>/dev/null)
  nix hash convert --hash-algo sha256 --to sri "$raw"
}

check_overlay() {
  local overlay="$1"
  local file="$OVERLAYS_DIR/$overlay"
  [[ -f "$file" ]] || return 0

  local pairs
  pairs=$(extract_pairs "$file") || return 0
  [[ -z "$pairs" ]] && return 0

  echo -e "${YELLOW}--- $overlay ---${NC}"
  while IFS=$'\t' read -r url current_hash; do
    ((total++)) || true
    local label
    label=$(basename "$url")
    echo -n "  $label ... "

    local actual_hash
    if actual_hash=$(sri_for_url "$url" 2>/dev/null); then
      if [[ "$actual_hash" == "$current_hash" ]]; then
        echo -e "${GREEN}ok${NC}"
      else
        echo -e "${RED}stale${NC}"
        echo "    old: $current_hash"
        echo "    new: $actual_hash"
        sed -i '' "s|${current_hash}|${actual_hash}|g" "$file"
        ((fixed++)) || true
      fi
    else
      echo -e "${RED}fetch failed (skipping)${NC}"
      ((errors++)) || true
    fi
  done <<< "$pairs"
}

# Overlays with pinned hashes for prebuilt binaries.
# Add new overlays here when introducing a prebuilt-binary package.
PINNED_OVERLAYS=(
  "20-ngrok.nix"
  "25-uv.nix"
  "30-mise.nix"
  "40-codex-openai.nix"
  "41-claude-code.nix"
  "50-trailbase.nix"
  "55-go.nix"
  "70-igir.nix"
  "91-dcg.nix"
  "95-aws-cdk-cli.nix"
)

echo "Checking hashes in prebuilt-binary overlays (this downloads each artifact)..."
echo ""

# Build target overlay list based on --only filter
declare -a TARGET_OVERLAYS
if [[ -n "$ONLY" ]]; then
  IFS=',' read -r -a names <<< "$ONLY"
  for n in "${names[@]}"; do
    file="$(jq -r --arg n "$n" \
      '.packages[] | select(.name==$n) | .overlay' \
      "$FLAKE_DIR/overlays/updates.json" | sed 's|overlays/||')"
    if [[ -z "$file" ]]; then
      warn "  (skip: '$n' not in updates.json)"; continue
    fi
    # Only re-hash overlays fix-hashes actually knows how to (prebuilt list).
    found=0
    for p in "${PINNED_OVERLAYS[@]}"; do
      if [[ "$p" == "$file" ]]; then
        TARGET_OVERLAYS+=("$file")
        found=1
        break
      fi
    done
    if [[ $found -eq 0 ]]; then
      warn "  (skip: '$n' -> '$file' not in PINNED_OVERLAYS)"
    fi
  done
else
  TARGET_OVERLAYS=("${PINNED_OVERLAYS[@]}")
fi

for overlay in "${TARGET_OVERLAYS[@]}"; do
  check_overlay "$overlay"
done

echo ""
echo "Checked $total URL(s): $fixed updated, $errors error(s)."
[[ $errors -eq 0 ]]
